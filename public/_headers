# Never cache the HTML document (any route → index.html via the SPA fallback)
# so every refresh re-fetches it and picks up the latest asset hashes.
# Defined before /assets/* so the more specific rule below wins for assets.
/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Content-hashed assets are safe to cache forever — their filenames change on
# every deploy, so a new build is never served stale.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
